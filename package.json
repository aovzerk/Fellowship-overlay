{
  "name": "fellowship-overlay",
  "version": "1.1.2",
  "description": "Fellowship overlay",
  "main": "src/main/index.js",
  "author": "AOV",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.aov.fellowshipoverlay",
    "productName": "Fellowship Overlay",
    "files": [
      "**/*",
      "!dist/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Fellowship-Overlay-Setup-${version}.${ext}",
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "installerHeaderIcon": "icons/icon.ico"
    }
  }
}
